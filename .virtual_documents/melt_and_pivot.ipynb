import pandas as pd

# Sample DataFrame
data = {
    'Name': ['Alice', 'Bob', 'Charlie'],
    'Math': [85, 78, 92],
    'Science': [90, 82, 89],
    'English': [88, 85, 94]
}

df = pd.DataFrame(data)

# Display the DataFrame
print(df)



df.melt(id_vars=["Name"],value_vars=["Math","Science","English"],var_name="Subject",value_name="Marks")


dict={
    "Name":["Alice","Alice","Alice","Bob","Bob"],
    "Subject":["Math","Math","Science","Math","Math"],
    "Score":[85,80,90,78,82]
}


df1=pd.DataFrame(dict)


df1


df1.pivot_table(index="Name",columns="Subject",values="Score")



